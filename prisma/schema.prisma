generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Zone {
  id        String   @id @default(cuid())
  name      String
  colorHex  String   @default("#6D5DD3") @map("color_hex")
  sortOrder Int      @default(0) @map("sort_order")
  clients   Client[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("zones")
}

model Client {
  id             String   @id @default(cuid())
  name           String
  address        String
  phone          String?
  email          String?
  contactPerson  String?  @map("contact_person")
  defaultPrice   Float    @default(0) @map("default_price")
  paymentMethod  String   @default("cash") @map("payment_method")
  frequencyWeeks Int      @default(4) @map("frequency_weeks")
  notes          String?
  status         String   @default("active")
  zoneId         String?  @map("zone_id")
  zone           Zone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  visits         Visit[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([zoneId, status])
  @@map("clients")
}

model Visit {
  id              String   @id @default(cuid())
  visitDate       DateTime @map("visit_date")
  amount          Float
  paymentMethod   String   @default("cash") @map("payment_method")
  paymentStatus   String   @default("paid") @map("payment_status")
  notes           String?
  durationMinutes Int?     @map("duration_minutes")
  completedAt     DateTime @default(now()) @map("completed_at")
  clientId        String   @map("client_id")
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([clientId, visitDate(sort: Desc)])
  @@map("visits")
}
